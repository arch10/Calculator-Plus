<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="BaseTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Color Themes — M3 semantic tokens with static-accent values as defaults -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceContainer">@color/surface</item>
        <item name="colorSurfaceContainerHigh">@color/surfaceContainerHigh</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorOnSurfaceVariant">@color/textSecondary</item>
        <item name="colorOutlineVariant">@color/border</item>
        <item name="colorError">@color/error</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnError">?attr/colorOnPrimary</item>
        <!-- Custom attrs re-pointed to M3 tokens so Dynamic Colors works for free -->
        <item name="textPrimary">?attr/colorOnSurface</item>
        <item name="textSecondary">?attr/colorOnSurfaceVariant</item>
        <item name="textAccent">?attr/colorOnPrimary</item>
        <item name="border">?attr/colorOutlineVariant</item>
        <item name="textDisable">@color/textDisable</item>
        <item name="numPadPrimary">?attr/colorSurfaceContainerHigh</item>
        <item name="operatorBtnColor">?attr/colorPrimary</item>
        <item name="clearColor">@color/clear</item>
        <item name="isLightTheme">true</item>
        <!-- Widget Themes -->
        <item name="materialAlertDialogTheme">
            @style/ThemeOverlay.CalculatorPlus.MaterialAlertDialog
        </item>
        <item name="switchStyle">@style/Widget.CalculatorPlus.Switch</item>
        <!-- Edge-to-edge support -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">?attr/isLightTheme</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
    </style>

    <style name="MaterialGreenTheme" parent="BaseTheme">
        <item name="colorPrimary">@color/primaryGreen</item>
        <item name="clearColor">@color/primaryGreenClear</item>
    </style>

    <style name="MaterialRedTheme" parent="BaseTheme">
        <item name="colorPrimary">@color/primaryRed</item>
        <item name="clearColor">@color/primaryRedClear</item>
    </style>

    <style name="MaterialPurpleTheme" parent="BaseTheme">
        <item name="colorPrimary">@color/primaryPurple</item>
        <item name="clearColor">@color/primaryPurpleClear</item>
    </style>

    <style name="MaterialGreyTheme" parent="BaseTheme">
        <item name="colorPrimary">@color/primaryGrey</item>
        <item name="clearColor">@color/primaryGreyClear</item>
    </style>

    <style name="MaterialPinkTheme" parent="BaseTheme">
        <item name="colorPrimary">@color/primaryPink</item>
        <item name="clearColor">@color/primaryPinkClear</item>
    </style>

    <!-- Dynamic theme: operatorBtnColor chains through colorPrimary so DynamicColors overlay works -->
    <style name="MaterialDynamicTheme" parent="BaseTheme" />

    <!-- Widget Styles -->
    <!-- NumPad.Secondary — accent-filled buttons (scientific pad + equals key).
         Explicit backgroundTint prevents transparent flash during ViewPager drag. -->
    <style name="Widget.CalculatorPlus.NumPad.Secondary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:maxLines">1</item>
        <item name="iconPadding">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- NumPad.Primary — neutral fill for digit/utility buttons. -->
    <style name="Widget.CalculatorPlus.NumPad.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="backgroundTint">?attr/colorSurfaceContainerHigh</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- NumPad.Operator — TextButton parent gives colorPrimary text via M3's own resolution
         (same mechanism as backgroundTint on filled buttons, reliable across all devices).
         backgroundTint tints the shape drawable to give a solid gray fill. -->
    <style name="Widget.CalculatorPlus.NumPad.Operator" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="backgroundTint">?attr/colorSurfaceContainerHigh</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.CalculatorPlus.NumPad.Primary.IconOnly" parent="Widget.CalculatorPlus.NumPad.Primary">
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/button_ripple</item>
    </style>

    <style name="ThemeOverlay.CalculatorPlus.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
    </style>

    <!-- Splash screen — postSplashScreenTheme transitions to the user-chosen accent at runtime -->
    <style name="Theme.CalculatorPlus.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/BaseTheme</item>
    </style>

    <style name="Widget.CalculatorPlus.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="materialThemeOverlay">@style/ThemeOverlay.CalculatorPlus.Switch</item>
    </style>

    <style name="ThemeOverlay.CalculatorPlus.Switch" parent="">
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorSecondary">?attr/operatorBtnColor</item>
    </style>

    <!-- Text Styles — M3 type scale parents -->
    <style name="TextAppearance.CalculatorPlus.Headline2" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>

    <style name="TextAppearance.CalculatorPlus.Headline3" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>

    <style name="TextAppearance.CalculatorPlus.Headline4" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Headline5" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Headline6" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Subtitle1" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Subtitle2" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Body2" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">?attr/textPrimary</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/textPrimary</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="TextAppearance.CalculatorPlus.Overline" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/textPrimary</item>
    </style>

</resources>