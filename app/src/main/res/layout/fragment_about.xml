<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.about.fragment.AboutFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:backgroundTint="?attr/colorSurface">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationContentDescription="Back"
            app:navigationIcon="@drawable/arrow_left"
            app:title="@string/title_activity_about" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/profileView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_xl">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:layout_marginTop="@dimen/space_xxl"
                android:src="@drawable/about_icon"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_l"
                android:layout_marginTop="@dimen/space_l"
                android:layout_marginEnd="@dimen/space_l"
                android:gravity="center"
                android:text="@string/app_name"
                android:textAppearance="@style/TextAppearance.CalculatorPlus.Headline5"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_l"
                android:layout_marginTop="@dimen/space_m"
                android:layout_marginEnd="@dimen/space_l"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.CalculatorPlus.Body1"
                android:textColor="?attr/textSecondary"
                tools:text="Version: 3.0.0" />

            <!-- Hidden: What's New — kept for changelog navigation -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_l"
                android:layout_marginTop="@dimen/space_xl"
                android:layout_marginEnd="@dimen/space_l"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/whatsNewCard"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/whatsNew"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_marginStart="@dimen/space_l"
                        android:layout_marginEnd="@dimen/space_l"
                        android:gravity="center_vertical"
                        android:text="@string/whats_new"
                        android:textAppearance="@style/TextAppearance.CalculatorPlus.Body1"
                        android:textColor="?attr/textPrimary"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Navigation items grouped like settings cards -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_l"
                android:layout_marginTop="@dimen/space_xl"
                android:layout_marginEnd="@dimen/space_l"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Join Beta -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/betaCard"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/beta"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/space_l"
                            android:layout_marginEnd="@dimen/space_l"
                            android:gravity="bottom"
                            android:text="@string/join_beta"
                            android:textAppearance="@style/TextAppearance.CalculatorPlus.Body1"
                            android:textColor="?attr/textPrimary"
                            app:layout_constraintBottom_toTopOf="@id/betaSubtitle"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/betaSubtitle"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/space_l"
                            android:layout_marginEnd="@dimen/space_l"
                            android:gravity="top"
                            android:paddingTop="2dp"
                            android:text="@string/join_beta_desc"
                            android:textAppearance="@style/TextAppearance.CalculatorPlus.Body2"
                            android:textColor="?attr/textDisable"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/beta" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/space_l"
                        android:layout_marginEnd="@dimen/space_l"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Open Source Licenses -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/openSourceCard"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/openSource"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/space_l"
                            android:layout_marginEnd="@dimen/space_l"
                            android:gravity="bottom"
                            android:text="@string/open_source"
                            android:textAppearance="@style/TextAppearance.CalculatorPlus.Body1"
                            android:textColor="?attr/textPrimary"
                            app:layout_constraintBottom_toTopOf="@id/openSourceSubtitle"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/openSourceSubtitle"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/space_l"
                            android:layout_marginEnd="@dimen/space_l"
                            android:gravity="top"
                            android:paddingTop="2dp"
                            android:text="@string/open_source_desc"
                            android:textAppearance="@style/TextAppearance.CalculatorPlus.Body2"
                            android:textColor="?attr/textDisable"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/openSource" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/space_l"
                        android:layout_marginEnd="@dimen/space_l"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Privacy Policy -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/privacyCard"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/privacy"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/space_l"
                            android:layout_marginEnd="@dimen/space_l"
                            android:gravity="bottom"
                            android:text="@string/privacy_policy"
                            android:textAppearance="@style/TextAppearance.CalculatorPlus.Body1"
                            android:textColor="?attr/textPrimary"
                            app:layout_constraintBottom_toTopOf="@id/privacySubtitle"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/privacySubtitle"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/space_l"
                            android:layout_marginEnd="@dimen/space_l"
                            android:gravity="top"
                            android:paddingTop="2dp"
                            android:text="@string/privacy_policy_desc"
                            android:textAppearance="@style/TextAppearance.CalculatorPlus.Body2"
                            android:textColor="?attr/textDisable"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/privacy" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/space_l"
                        android:layout_marginEnd="@dimen/space_l"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Terms of Use -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/termsCard"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/terms"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/space_l"
                            android:layout_marginEnd="@dimen/space_l"
                            android:gravity="bottom"
                            android:text="@string/terms_of_use"
                            android:textAppearance="@style/TextAppearance.CalculatorPlus.Body1"
                            android:textColor="?attr/textPrimary"
                            app:layout_constraintBottom_toTopOf="@id/termsSubtitle"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/termsSubtitle"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_marginStart="@dimen/space_l"
                            android:layout_marginEnd="@dimen/space_l"
                            android:gravity="top"
                            android:paddingTop="2dp"
                            android:text="@string/terms_of_use_desc"
                            android:textAppearance="@style/TextAppearance.CalculatorPlus.Body2"
                            android:textColor="?attr/textDisable"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/terms" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
